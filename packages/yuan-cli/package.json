{
  "name": "@yuaone/cli",
  "version": "0.3.4",
  "description": "YUAN — Autonomous Coding Agent CLI",
  "license": "AGPL-3.0",
  "type": "module",
  "bin": {
    "yuan": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yuaone/yuan.git",
    "directory": "packages/yuan-cli"
  },
  "homepage": "https://github.com/yuaone/yuan#readme",
  "bugs": {
    "url": "https://github.com/yuaone/yuan/issues"
  },
  "keywords": [
    "coding-agent",
    "ai",
    "autonomous",
    "cli",
    "llm",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@yuaone/core": "workspace:*",
    "@yuaone/tools": "workspace:*",
    "ansi-escapes": "7.0.0",
    "chalk": "5.4.1",
    "cli-cursor": "5.0.0",
    "commander": "^13.1.0",
    "ink": "5.1.0",
    "ink-text-input": "6.0.0",
    "react": "18.3.1",
    "string-width": "7.2.0",
    "strip-ansi": "7.1.0",
    "wrap-ansi": "9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/react": "18.3.0",
    "typescript": "^5.7.0"
  }
}
